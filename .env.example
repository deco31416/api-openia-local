# ChatGPT Web Bridge — Variables de entorno
# Copia este archivo como .env y personaliza

# API Key para exponer el bridge fuera de localhost
# Si se define, todos los endpoints (excepto /health, /dashboard, /docs) requieren X-API-Key
BRIDGE_API_KEY=cambia-esta-key-por-una-secreta

# URL de ChatGPT Web
CHATGPT_URL=https://chatgpt.com/

# Puerto y host
BRIDGE_PORT=9090
BRIDGE_HOST=127.0.0.1
